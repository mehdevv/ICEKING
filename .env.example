# LoyalQR — copy to .env (see .env for your real keys)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local dev (npm run dev):
#   App:      http://localhost:5173
#   Admin:    http://localhost:5173/admin
#   Employee: http://localhost:5173/employee
#   Client:   http://localhost:5173/client
#   Dashboard http://localhost:5173/dashboard
#
# Edge functions: {VITE_SUPABASE_URL}/functions/v1/<name>
# Full list: supabase/functions/LINKS.md
